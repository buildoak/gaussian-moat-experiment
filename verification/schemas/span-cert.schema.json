{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaussian-moat.local/schemas/span-cert.schema.json",
  "title": "SPANNING coordinate certificate",
  "type": "object",
  "required": ["schema_version", "k_sq", "r_inner", "r_outer", "region", "path"],
  "properties": {
    "schema_version": { "const": 1 },
    "claim_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\s\\x00-\\x1f\\x7f]+$"
    },
    "k_sq": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "r_inner": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "r_outer": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "region": { "enum": ["full-octant"] },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\x00-\\x1f\\x7f]+$"
    },
    "path": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["a", "b"],
        "properties": {
          "a": { "type": "integer", "minimum": 0, "maximum": 9223372036854775807 },
          "b": { "type": "integer", "minimum": 0, "maximum": 9223372036854775807 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
