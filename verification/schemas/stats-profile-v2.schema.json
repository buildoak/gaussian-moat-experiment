{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaussian-moat.local/schemas/stats-profile-v2.schema.json",
  "title": "Gaussian moat stats profile v2 extension",
  "description": "Profile telemetry schema plus the normalized sweep row contract used by verification/stats/normalize_sweep_rows.py. Nullable normalized fields are intentional so older profile JSON can be represented without inventing measurements.",
  "type": "object",
  "required": ["schema_version", "radii", "verdict", "tiles", "overflow_counters"],
  "$defs": {
    "nonNegativeInteger": { "type": "integer", "minimum": 0 },
    "nullableInteger": { "type": ["integer", "null"] },
    "nullableNumber": { "type": ["number", "null"] },
    "nullableString": { "type": ["string", "null"] },
    "nullableBoolean": { "type": ["boolean", "null"] },
    "detectorStatus": {
      "enum": [
        "ANY_SPAN_DETECTED",
        "ANY_SHELL_MOAT_DETECTED",
        "UNKNOWN_DETECTOR_STATUS"
      ]
    },
    "proofStatus": {
      "enum": [
        "CLAIM_PROOF_MISSING",
        "MOAT_PROOF_PASS",
        "SPAN_PROOF_PASS"
      ]
    },
    "postflightStatus": {
      "enum": [
        null,
        "CLAIM_PROOF_MISSING",
        "MOAT_PROOF_PASS",
        "REJECT",
        "RUN_CONTRACT_PASS",
        "SPAN_PROOF_PASS",
        "TILE_SAMPLE_AUDIT_PASS"
      ]
    },
    "distributionBucket": {
      "type": "object",
      "required": ["value", "count"],
      "properties": {
        "value": { "$ref": "#/$defs/nonNegativeInteger" },
        "count": { "$ref": "#/$defs/nonNegativeInteger" }
      },
      "additionalProperties": false
    },
    "distribution": {
      "type": "object",
      "required": ["buckets", "observed_min", "observed_max", "sample_count", "total_count"],
      "properties": {
        "buckets": {
          "type": "array",
          "items": { "$ref": "#/$defs/distributionBucket" }
        },
        "observed_min": { "$ref": "#/$defs/nonNegativeInteger" },
        "observed_max": { "$ref": "#/$defs/nonNegativeInteger" },
        "sample_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "total_count": { "$ref": "#/$defs/nonNegativeInteger" }
      },
      "additionalProperties": false
    },
    "nullableDistribution": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/distribution" }
      ]
    },
    "highPressureTile": {
      "type": "object",
      "required": [
        "tile_index",
        "tile_i",
        "tile_j",
        "group_count",
        "total_port_count",
        "max_face_port_count",
        "geo_i",
        "geo_o",
        "classes"
      ],
      "properties": {
        "tile_index": { "$ref": "#/$defs/nonNegativeInteger" },
        "tile_i": { "$ref": "#/$defs/nonNegativeInteger" },
        "tile_j": { "$ref": "#/$defs/nonNegativeInteger" },
        "candidate_count": { "$ref": "#/$defs/nullableInteger" },
        "gaussian_prime_count": { "$ref": "#/$defs/nullableInteger" },
        "group_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "total_port_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "max_face_port_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "score": { "$ref": "#/$defs/nonNegativeInteger" },
        "pressure_score": { "$ref": "#/$defs/nonNegativeInteger" },
        "a_lo": { "type": "integer" },
        "b_lo": { "type": "integer" },
        "face_port_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonNegativeInteger" },
          "minItems": 4,
          "maxItems": 4
        },
        "geo_i": { "type": "boolean" },
        "geo_o": { "type": "boolean" },
        "overflow": { "type": "boolean" },
        "classes": {
          "type": "array",
          "items": {
            "enum": [
              "candidate",
              "gaussian_prime",
              "group",
              "total_port",
              "max_face_port",
              "geo_i",
              "geo_o",
              "overflow"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "componentSummary": {
      "type": "object",
      "required": ["rank", "component_id", "tile_count", "group_count", "geo_i", "geo_o"],
      "properties": {
        "rank": { "$ref": "#/$defs/nonNegativeInteger" },
        "component_id": { "$ref": "#/$defs/nonNegativeInteger" },
        "tile_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "group_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "geo_i": { "type": "boolean" },
        "geo_o": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "componentCensus": {
      "type": "object",
      "required": [
        "total_components",
        "i_only_components",
        "o_only_components",
        "i_and_o_components",
        "largest_component_sizes",
        "largest_boundary_touching_components"
      ],
      "properties": {
        "total_components": { "$ref": "#/$defs/nonNegativeInteger" },
        "i_only_components": { "$ref": "#/$defs/nonNegativeInteger" },
        "o_only_components": { "$ref": "#/$defs/nonNegativeInteger" },
        "i_and_o_components": { "$ref": "#/$defs/nonNegativeInteger" },
        "neither_components": { "$ref": "#/$defs/nonNegativeInteger" },
        "initialized": { "type": "boolean" },
        "spanning_detected": { "type": "boolean" },
        "live_frontier_only": { "type": "boolean" },
        "live_group_nodes": { "$ref": "#/$defs/nonNegativeInteger" },
        "largest_component_sizes": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentSummary" }
        },
        "largest_boundary_touching_components": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentSummary" }
        }
      },
      "additionalProperties": false
    },
    "normalizedSweepRow": {
      "type": "object",
      "required": [
        "sweep_row_schema_version",
        "source_profile",
        "claim_id",
        "k_sq",
        "r_inner",
        "r_outer",
        "width",
        "region",
        "verdict",
        "verdict_mode",
        "detector_status",
        "proof_status"
      ],
      "properties": {
        "sweep_row_schema_version": { "const": 1 },
        "source_profile": { "type": "string" },
        "source_audit": { "$ref": "#/$defs/nullableString" },
        "claim_id": { "type": "string", "minLength": 1 },
        "k_sq": { "$ref": "#/$defs/nullableInteger" },
        "r_inner": { "$ref": "#/$defs/nullableInteger" },
        "r_outer": { "$ref": "#/$defs/nullableInteger" },
        "width": { "$ref": "#/$defs/nullableInteger" },
        "region": { "$ref": "#/$defs/nullableString" },
        "verdict": { "enum": ["SPANNING", "MOAT", "UNKNOWN", null] },
        "verdict_mode": { "enum": ["ANY-SPAN", "ANY-SHELL-MOAT", null] },
        "detector_status": { "$ref": "#/$defs/detectorStatus" },
        "proof_status": { "$ref": "#/$defs/proofStatus" },
        "postflight_status": { "$ref": "#/$defs/postflightStatus" },
        "run_contract_status": { "$ref": "#/$defs/postflightStatus" },
        "tile_sample_audit_status": { "$ref": "#/$defs/postflightStatus" },
        "telemetry_level": { "enum": ["none", "profile", "audit", "full", null] },
        "active_tiles": { "$ref": "#/$defs/nullableInteger" },
        "produced_tiles": { "$ref": "#/$defs/nullableInteger" },
        "ingested_tiles": { "$ref": "#/$defs/nullableInteger" },
        "early_exit_enabled": { "$ref": "#/$defs/nullableBoolean" },
        "early_exit_taken": { "$ref": "#/$defs/nullableBoolean" },
        "bz_checked": { "$ref": "#/$defs/nullableBoolean" },
        "bz_clean": { "$ref": "#/$defs/nullableBoolean" },
        "bz_override_used": { "$ref": "#/$defs/nullableBoolean" },
        "bz_bad_norm_count": { "$ref": "#/$defs/nullableInteger" },
        "overflow_total": { "$ref": "#/$defs/nullableInteger" },
        "emitted_overflow_bit_count": { "$ref": "#/$defs/nullableInteger" },
        "geo_i_tiles": { "$ref": "#/$defs/nullableInteger" },
        "geo_o_tiles": { "$ref": "#/$defs/nullableInteger" },
        "geo_i_ports": { "$ref": "#/$defs/nullableInteger" },
        "geo_o_ports": { "$ref": "#/$defs/nullableInteger" },
        "candidate_count_distribution": { "$ref": "#/$defs/nullableDistribution" },
        "gaussian_prime_count_distribution": { "$ref": "#/$defs/nullableDistribution" },
        "group_count_distribution": { "$ref": "#/$defs/nullableDistribution" },
        "total_port_count_distribution": { "$ref": "#/$defs/nullableDistribution" },
        "max_face_port_count_distribution": { "$ref": "#/$defs/nullableDistribution" },
        "high_pressure_tiles": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/highPressureTile" }
            }
          ]
        },
        "component_census": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/componentCensus" }
          ]
        },
        "sample_manifest_path": { "$ref": "#/$defs/nullableString" },
        "tile_sample_path": { "$ref": "#/$defs/nullableString" },
        "sample_count": { "$ref": "#/$defs/nullableInteger" },
        "snapshot_path": { "$ref": "#/$defs/nullableString" },
        "snapshot_sha256": { "$ref": "#/$defs/nullableString" },
        "total_seconds": { "$ref": "#/$defs/nullableNumber" },
        "cuda_k1_k5_seconds": { "$ref": "#/$defs/nullableNumber" },
        "compositor_seconds": { "$ref": "#/$defs/nullableNumber" }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "telemetry_level": { "enum": ["none", "profile", "audit", "full"] },
    "radii": {
      "type": "object",
      "required": ["k_sq", "r_inner", "r_outer"],
      "properties": {
        "k_sq": { "type": "integer", "minimum": 1 },
        "r_inner": { "$ref": "#/$defs/nonNegativeInteger" },
        "r_outer": { "$ref": "#/$defs/nonNegativeInteger" },
        "width": { "$ref": "#/$defs/nonNegativeInteger" }
      },
      "additionalProperties": true
    },
    "verdict": { "enum": ["SPANNING", "MOAT", "UNKNOWN"] },
    "tiles": {
      "type": "object",
      "properties": {
        "active": { "$ref": "#/$defs/nonNegativeInteger" },
        "produced": { "$ref": "#/$defs/nonNegativeInteger" },
        "ingested": { "$ref": "#/$defs/nonNegativeInteger" },
        "columns_ingested": { "$ref": "#/$defs/nonNegativeInteger" }
      },
      "additionalProperties": true
    },
    "overflow_counters": {
      "type": "object",
      "properties": {
        "k1_cand_overflow_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "k4_prime_overflow_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "k4_group_overflow_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "k5_port_overflow_count": { "$ref": "#/$defs/nonNegativeInteger" }
      },
      "additionalProperties": true
    },
    "bz": {
      "type": "object",
      "properties": {
        "clean": { "type": "boolean" },
        "override_used": { "type": "boolean" },
        "record_path": { "type": "string" }
      }
    },
    "stats_v2": {
      "type": "object",
      "properties": {
        "stats_level": { "type": "string" },
        "telemetry_level": { "enum": ["none", "profile", "audit", "full"] },
        "geo_i_tiles": { "type": "integer", "minimum": 0 },
        "geo_o_tiles": { "type": "integer", "minimum": 0 },
        "geo_i_ports": { "type": "integer", "minimum": 0 },
        "geo_o_ports": { "type": "integer", "minimum": 0 },
        "candidate_count_distribution": { "$ref": "#/$defs/distribution" },
        "gaussian_prime_count_distribution": { "$ref": "#/$defs/distribution" },
        "group_count_distribution": { "$ref": "#/$defs/distribution" },
        "total_port_count_distribution": { "$ref": "#/$defs/distribution" },
        "max_face_port_count_distribution": { "$ref": "#/$defs/distribution" },
        "high_pressure_tiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/highPressureTile" }
        },
        "component_census": { "$ref": "#/$defs/componentCensus" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "tile_samples_written": { "type": "integer", "minimum": 0 },
        "sample_seed": { "type": "integer" },
        "sample_target_count": { "type": "integer", "minimum": 0 },
        "span_cert_path": { "type": "string" },
        "sample_manifest_path": { "type": "string" },
        "tile_sample_path": { "type": "string" },
        "snapshot_path": { "type": "string" },
        "snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
